# Firebase Admin (crear en Firebase Console -> Project Settings -> Service Accounts)
FIREBASE_PROJECT_ID=tu-proyecto
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# OpenRouter (IA gratis - ya tienes la key en el .env del proyecto Flutter)
OPENROUTER_API_KEY=sk-or-v1-...

# Puerto (opcional, default 3000)
PORT=3000
